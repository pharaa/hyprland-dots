{
  "layer": "bottom",
  "position": "top",
  "margin":"5px",
  "height": 36,
  "width": 1910,
  "spacing": 2,
  "exclusive": true,
  "gtk-layer-shell": true,
  "passthrough": false,
  "fixed-center": true,
  "modules-left": [
	"custom/launcher",
  "hyprland/workspaces",
  "hyprland/window"
  ],
  "modules-center": [
    "mpris"
  ],
  "modules-right": [
    "cpu",
    "memory",
    "pulseaudio",
    "hyprland/language",
    "clock",
    "tray",
    "custom/notification",
    "custom/power"
  ],
  /* Для красоты */
  "custom/launcher": {
    "format" : "󰣇",
    "on-click" : "fuzzel",
    "tooltip" : false
  },
  /* Текущая раскладка*/
  "hyprland/language": {
    "format":"󰌌 {short} {variant}",
    "tooltip": false
  },
  /* Плеер */
  "mpris": {
    "player": "playerctld",
    "dynamic-order": ["artist", "title"],
    "format": "{player_icon} {dynamic}",
    "format-paused": "{status_icon} {dynamic}",
    "max-length": 60,
    "ellipsis": "...",
    "status-icons": {
      "paused": ""
    },
    "player-icons": {
      "default": ""
    }
  },
  /* Рабочие столы */
  "hyprland/workspaces": {
    "on-click": "activate",
    "format": "{id}",
    "all-outputs": true,
    "disable-scroll": false,
    "active-only": false
  },
  /* Текущее окно */
  "hyprland/window": {
		"format": "{class}",
		"separate-outputs": false
	},
  /* Трей */
  "tray": {
    "show-passive-items": true,
    "spacing": 10
  },
  /* Часы */
  "clock": {
    "format": " {:%H:%M}",
    "format-alt": " {:L%a %d %b}",
    "calendar": {
      "format": {
        "days": "<span weight='normal'>{}</span>",
        "months": "<span color='#cdd6f4'><b>{}</b></span>",
        "today": "<span color='#f38ba8' weight='700'><u>{}</u></span>",
        "weekdays": "<span color='#cdd6f4'><b>{}</b></span>",
        "weeks": "<span color='#cdd6f4'><b>W{}</b></span>"
      },
      "mode": "month",
      "mode-mon-col": 1,
      "on-scroll": 1
    },
    "tooltip-format": "<span color='#cdd6f4' font='JetBrainsMono NFP 15'><tt><small>{calendar}</small></tt></span>"
  },
  /* Проц */
  "cpu": {
    "format": " {usage}%",
    "tooltip": true,
    "interval": 1
  },
  /* Опра */
  "memory": {
    "format": " {used:0.1f}Gi"
  },
  /* Громкость */
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "  muted",
    "format-icons": {
      "headphone": "",
      "default": [" ", " ", " "]
    },
    "on-click": "pavucontrol"
  },
  /* Менюшка выключения*/
  "custom/power": {
    "tooltip": false,
    "on-click": "wlogout -p layer-shell &",
    "format": "⏻"
  },
  /* Уведы */
  "custom/notification": {
    "escape": true,
    "exec": "swaync-client -swb",
    "exec-if": "which swaync-client",
    "format": "{icon}",
    "format-icons": {
      "none": "󰅺",
      "notification": "󰡟"
    },
    "on-click": "sleep 0.1 && swaync-client -t -sw",
    "return-type": "json",
    "tooltip": false
  }
}
